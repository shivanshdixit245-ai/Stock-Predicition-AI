# Stock Signal Platform — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to GitHub

# NewsAPI (free tier — get key at newsapi.org)
NEWS_API_KEY=your_newsapi_key_here

# Anthropic API (for AI Assistant tab)
# Get key at console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# MLflow (leave as default for local use)
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=stock-signal-platform

# App settings
DEFAULT_TICKER=AAPL
SIGNAL_BUY_THRESHOLD=0.65
SIGNAL_SELL_THRESHOLD=0.35
INITIAL_CAPITAL=100000
TRANSACTION_COST_PCT=0.001
BOOTSTRAP_N=10000
PSI_THRESHOLD=0.2
N_CV_FOLDS=12
